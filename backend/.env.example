# Postgres connection (Railway provides DATABASE_URL automatically when you attach a Postgres plugin)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskmanager
ENVIRONMENT=development

# JWT settings — generate a long random string for production: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
